TMDB_API_KEY=f728f7197fc9c3a7dfb35d78478d7e8e
TMDB_READ_ACCESS_TOKEN=eyJhbGciOiJIUzI1NiJ9.eyJhdWQiOiJmNzI4ZjcxOTdmYzljM2E3ZGZiMzVkNzg0NzhkN2U4ZSIsIm5iZiI6MTc4MzYzMTI0Ni45NDEsInN1YiI6IjZhNTAwZDhlMzZhNjU2NDY2NDRjYjNjYSIsInNjb3BlcyI6WyJhcGlfcmVhZCJdLCJ2ZXJzaW9uIjoxfQ.__2iQ3kTDL9grTehobYQNJ8lu6myQui-TC-JRaxquQ0

# ─── VidLink Direct Resolver ─────────────────────────────────
# Enables DIRECT stream URLs (m3u8/mp4) instead of embed pages.
# You need to run a VidLink resolver API somewhere (e.g. Railway).
# Leave EMPTY if you don't have one — embed fallbacks still work.
#VIDLINK_RESOLVER_BASE_URL=https://your-vidlink-resolver.com
#VIDLINK_API_BASE_URL=https://your-vidlink-resolver.com

# ─── OMSS Resolver ───────────────────────────────────────────
# Another direct stream resolver. Same idea as VidLink Direct.
# Leave EMPTY if you don't have one — not required.
#OMSS_BASE_URL=https://your-omss-resolver.com
#OMSS_API_BASE_URL=https://your-omss-resolver.com

# ─── CinePro / CineHub Resolver ──────────────────────────────
# Another direct stream resolver for movies/TV.
# Leave EMPTY if you don't have one.
#CINEPRO_BASE_URL=https://your-cinepro-resolver.com
#CINEHUB_BASE_URL=https://your-cinehub-resolver.com
#CINEPRO_API_BASE_URL=https://your-cinepro-resolver.com

# ─── Consumet API ─────────────────────────────────────────────
# Required for ANIME streaming (Gogoanime, HiAnime, etc.).
# Run your own Consumet instance or use a public one.
# Example public instance (reliability varies):
#CONSUMET_BASE_URL=https://consumet-api-sd9x.onrender.com
#CONSUMET_API_BASE_URL=https://consumet-api-sd9x.onrender.com

# ─── Football / Sports ────────────────────────────────────────
# API-Sports football API key. Get at: https://www.api-football.com/
# REQUIRED for football streaming to work.
#SPORTS_API_KEY=your_api_sports_key_here

# ─── Built-in Embed Providers (NO env var needed) ─────────────
# These are hardcoded in the server and ALWAYS work:
#   - VidLink Pro     → https://vidlink.pro/movie/{id}
#   - AutoEmbed       → https://player.autoembed.cc/movie/{id}
#   - VidSrc.me       → https://vidsrc.me/embed/movie?tmdb={id}
#   - EmbedSu         → https://embed.su/embed/movie/{id}
#   - VidSrc.cc       → https://vidsrc.cc/v2/embed/movie/{id}
#   - 2Embed          → https://2embed.cc/embed/{id}

# ─── App Config (already set on Render, listed for reference) ─
#PORT=3000
#PUBLIC_APP_URL=https://novelapp1.onrender.com
#RENDER_EXTERNAL_URL=https://novelapp1.onrender.com

# ─── Supabase (already set on Render) ─────────────────────────
#SUPABASE_URL=https://your-project.supabase.co
#SUPABASE_SECRET_KEY=your_service_role_key
#supabase_url=https://your-project.supabase.co
#project_url=https://your-project.supabase.co

# ─── Flutterwave (already set on Render) ──────────────────────
#FLUTTERWAVE_SECRET_KEY=your_flutterwave_secret
#FLUTTERWAVE_SECRET_HASH=your_flutterwave_webhook_hash

# ─── Google API (has hardcoded fallback) ──────────────────────
#GOOGLE_API_KEY=your_google_api_key_here

# ─── RapidAPI for WebNovels (if used) ────────────────────────
#RAPID_API_KEY=your_rapidapi_key
#RAPID_API_HOST=webnovel.p.rapidapi.com
